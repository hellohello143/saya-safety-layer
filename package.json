{
  "name": "agent-payment-safety-layer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Saya — scoped, on-chain-enforced session keys for autonomous AI-agent payments over x402. USDC on Base (CDP Spend Permissions) and Solana (SPL delegation), testnet or mainnet.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "tsx scripts/setup.ts",
    "mock-seller": "tsx mock-seller/server.ts",
    "agent-sim": "tsx scripts/agent-sim.ts"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "1.51.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^8.1.1",
    "@solana-program/token": "0.9.0",
    "@solana/kit": "5.5.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "viem": "^2.54.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
