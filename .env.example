# ============================================================================
# AI Agent Payment Safety Layer — environment configuration
# Copy to `.env` and fill in. NEVER commit `.env`. Secrets only via env.
# ============================================================================

# ----------------------------------------------------------------------------
# Coinbase Developer Platform (CDP) credentials
# Get these from the CDP Portal: https://portal.cdp.coinbase.com
#   - Create a "Secret API Key" (gives API_KEY_ID + API_KEY_SECRET)
#   - Create/note the "Wallet Secret" used to authorize wallet operations
# The Node SDK (@coinbase/cdp-sdk) reads exactly these three names by default.
# Docs: https://docs.cdp.coinbase.com/server-wallets/v2/introduction/quickstart
# ----------------------------------------------------------------------------
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ----------------------------------------------------------------------------
# Network / accounts
# ----------------------------------------------------------------------------
# EVM (NETWORK is the legacy alias for EVM_NETWORK): base-sepolia | base.
#   base-sepolia  → testnet, free test USDC via faucet (SAFE DEFAULT)
#   base          → MAINNET, REAL FUNDS (no faucet; fund with real USDC).
NETWORK=base-sepolia

# Solana runs ALONGSIDE EVM. off | solana-devnet | solana.
#   solana-devnet → testnet, faucet SOL (fees) + USDC. Solana needs SOL for gas.
#   solana        → MAINNET, REAL FUNDS.
# ⚠️ On Solana, expiresAt is enforced SOFT-ONLY (SPL delegation has no on-chain
#   time bound); total-cap + revocation ARE on-chain. See TRUST_BOUNDARY.md.
SOLANA_NETWORK=off

# Named CDP accounts (getOrCreate is idempotent by name).
#  - OWNER: the CDP-managed EOA that owns the smart account (REQUIRED: spend
#    permissions only work on smart accounts owned by a CDP Server Wallet).
#  - SMART_ACCOUNT: the agent's treasury smart account that holds test USDC.
#  - SPENDER: the safety-layer's spender account that pulls funds within a
#    permission. NOTE: on-chain, spend() delivers funds to THIS spender, not to
#    the merchant — the merchant is paid in a separate x402 leg the backend
#    controls. See docs/research/CDP_X402_RESEARCH.md §6 & §9.
CDP_OWNER_ACCOUNT_NAME=safety-owner
CDP_SMART_ACCOUNT_NAME=safety-treasury
CDP_SPENDER_ACCOUNT_NAME=safety-spender
# Solana accounts: treasury holds USDC + pays SOL fees; spender is the delegate.
CDP_SOLANA_TREASURY_ACCOUNT_NAME=safety-treasury-sol
CDP_SOLANA_SPENDER_ACCOUNT_NAME=safety-spender-sol

# USDC_ADDRESS and RPC_URL are derived from NETWORK — only set these to override.
#   base-sepolia USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
#   base (mainnet) USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# USDC_ADDRESS=
# RPC_URL=

# SpendPermissionManager singleton (same address on every supported chain).
# Used for direct on-chain validity reads (isValid/getCurrentPeriod) via viem.
SPEND_PERMISSION_MANAGER_ADDRESS=0xf85210B21cC50302F477BA56686d2019dC9b67Ad

# ----------------------------------------------------------------------------
# Backend server + auth
# ----------------------------------------------------------------------------
PORT=3000
HOST=127.0.0.1

# API_TOKEN protects all /api/* routes (Bearer token). `npm run setup` generates
# one automatically if this is blank. REQUIRED on mainnet — the server refuses to
# start on base/solana without it. Leave blank for a no-auth local testnet run.
API_TOKEN=

# ----------------------------------------------------------------------------
# Database (SQLite via Drizzle). Swap to Postgres later = config + migration.
# ----------------------------------------------------------------------------
DATABASE_URL=./data/safety-layer.db

# ----------------------------------------------------------------------------
# Circuit breaker (soft rate limit). Counts ALL payment attempts (not just
# successes) in a rolling window; tripping auto-suspends + revokes on-chain.
# ----------------------------------------------------------------------------
CIRCUIT_BREAKER_MAX_ATTEMPTS=10
CIRCUIT_BREAKER_WINDOW_SECONDS=60

# ----------------------------------------------------------------------------
# Mock x402 seller (local test resource server)
# ----------------------------------------------------------------------------
MOCK_SELLER_PORT=4021
# Address the mock seller is paid at (its payTo). Settlement is a REAL on-chain
# USDC transfer, so set this to an address YOU control to receive the test USDC.
# If unset it defaults to the burn address 0x...dEaD (payments are real but burned).
MOCK_SELLER_PAY_TO=
# Price the mock seller charges per request, in USDC (decimal string).
MOCK_SELLER_PRICE_USDC=0.01
